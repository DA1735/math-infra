# --------------------------------------------------------------------------
# STRICT SECURITY RULES (Never commit these files)
# --------------------------------------------------------------------------
.env
.env.*
*.local

# Keys & Certificates
id_*
*.pem
*.key
*.p12
*.pfx
.ssh/

# Credentials & Tokens
*.json
.aws/
.azure/
docker/config.json
.npmrc
.pypirc
.netrc

# --------------------------------------------------------------------------
# Python & uv Environment
# --------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.venv/
.venv
dist/
build/
*.egg-info/

# --------------------------------------------------------------------------
# Node.js (If used in future)
# --------------------------------------------------------------------------
node_modules/

# --------------------------------------------------------------------------
# macOS Specific
# --------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon\r
._*

# --------------------------------------------------------------------------
# IDEs & Editors
# --------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# --------------------------------------------------------------------------
# Infrastructure specific ignores
# --------------------------------------------------------------------------
# Do not commit raw backups or secret device configs
configs/*.bak
configs/*_secret.txt
configs/asa_secrets/
